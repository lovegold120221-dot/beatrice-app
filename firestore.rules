rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations (Pillar 2)
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 3 && data.keys().size() <= 5 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             ( !('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128) ) &&
             ( !('googleAccessToken' in data) || (data.googleAccessToken is string && data.googleAccessToken.size() <= 2048) );
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['userId', 'content', 'type', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 5 && data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 50000 &&
             data.type in ['preference', 'fact', 'summary', 'snippet', 'email', 'whatsapp'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             ( !('sourceUrl' in data) || (data.sourceUrl is string && data.sourceUrl.size() <= 512) );
    }

    function isValidWhatsAppMessage(data) {
      return data.keys().hasAll(['userId', 'from', 'to', 'body', 'status', 'timestamp']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.from is string && data.from.size() <= 128 &&
             data.to is string && data.to.size() <= 128 &&
             data.body is string && data.body.size() <= 5000 &&
             data.status in ['sent', 'received', 'failed'] &&
             data.timestamp == request.time;
    }

    function isValidFile(data) {
      return data.keys().hasAll(['userId', 'filename', 'status', 'type', 'mimeType', 'size', 'storageUrl', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.filename is string && data.filename.size() <= 256 &&
             data.status in ['indexed', 'processing', 'failed'] &&
             data.type is string &&
             data.mimeType is string && data.mimeType.size() <= 128 &&
             data.size is number && data.size > 0 && data.size <= 1048576 * 100 && // 100MB
             data.storageUrl is string && data.storageUrl.size() <= 1024 &&
             data.createdAt is timestamp;
    }

    function isValidAnnotation(data) {
      return data.keys().hasAll(['userId', 'fileId', 'textSelection', 'comment', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.fileId is string && data.fileId.size() <= 128 &&
             data.textSelection is string && data.textSelection.size() <= 2000 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['userId', 'title', 'dueDate', 'completed', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 256 &&
             data.dueDate is timestamp &&
             data.completed is bool &&
             data.createdAt == request.time;
    }

    // Pillar 1: Master Gate (Relational Sync)
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'googleAccessToken', 'updatedAt']) &&
        incoming().updatedAt == request.time &&
        ( !('displayName' in incoming()) || (incoming().displayName is string && incoming().displayName.size() <= 128) ) &&
        ( !('googleAccessToken' in incoming()) || (incoming().googleAccessToken is string && incoming().googleAccessToken.size() <= 2048) )
      );

      match /memories/{memoryId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && isValidId(memoryId);
        allow create: if isOwner(userId) && isValidId(memoryId) && isValidMemory(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow update: if isOwner(userId) && isValidId(memoryId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']) &&
          incoming().updatedAt == request.time &&
          incoming().content is string && incoming().content.size() <= 50000
        );
        allow delete: if isOwner(userId) && isValidId(memoryId);
      }

      match /files/{fileId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && isValidId(fileId);
        allow create: if isOwner(userId) && isValidId(fileId) && isValidFile(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if isOwner(userId) && isValidId(fileId);
      }

      match /annotations/{annotationId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && isValidId(annotationId);
        allow create: if isOwner(userId) && isValidId(annotationId) && isValidAnnotation(incoming()) && 
                    exists(/databases/$(database)/documents/users/$(userId)) &&
                    exists(/databases/$(database)/documents/users/$(userId)/files/$(incoming().fileId));
        allow delete: if isOwner(userId) && isValidId(annotationId);
      }

      match /reminders/{reminderId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && isValidId(reminderId);
        allow create: if isOwner(userId) && isValidId(reminderId) && isValidReminder(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow update: if isOwner(userId) && isValidId(reminderId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'title', 'dueDate']) &&
          ( !('title' in incoming()) || (incoming().title is string && incoming().title.size() <= 256) ) &&
          ( !('dueDate' in incoming()) || incoming().dueDate is timestamp ) &&
          ( !('completed' in incoming()) || incoming().completed is bool )
        );
        allow delete: if isOwner(userId) && isValidId(reminderId);
      }

      match /whatsapp_messages/{messageId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && isValidId(messageId);
        allow create: if isOwner(userId) && isValidId(messageId) && isValidWhatsAppMessage(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if isOwner(userId) && isValidId(messageId);
      }
    }
  }
}
