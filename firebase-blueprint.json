{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "googleAccessToken": { "type": "string", "description": "Securely stored transient access token for Google APIs" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Information stored by Beatrice about the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["preference", "fact", "summary", "snippet", "email", "whatsapp"] },
        "sourceUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "content", "type", "createdAt", "updatedAt"]
    },
    "WhatsAppMessage": {
      "title": "WhatsAppMessage",
      "description": "Log of WhatsApp messages sent or received via Beatrice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "received", "failed"] },
        "timestamp": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "from", "to", "body", "status", "timestamp"]
    },
    "UploadedFile": {
      "title": "UploadedFile",
      "description": "Metadata for files uploaded to Beatrice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "filename": { "type": "string" },
        "status": { "type": "string", "enum": ["indexed", "processing", "failed"] },
        "type": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "storageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "filename", "status", "type", "mimeType", "size", "storageUrl", "createdAt"]
    },
    "Annotation": {
      "title": "Annotation",
      "description": "User notes on specific document segments",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileId": { "type": "string" },
        "textSelection": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "fileId", "textSelection", "comment", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "User-defined tasks or event alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "dueDate": { "type": "string", "format": "timestamp" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "title", "dueDate", "completed", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Id is the Firebase Auth UID."
    },
    "users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Memories owned by the specific user."
    },
    "users/{userId}/files/{fileId}": {
      "schema": { "$ref": "#/entities/UploadedFile" },
      "description": "Uploaded file metadata owned by the user."
    },
    "users/{userId}/annotations/{annotationId}": {
      "schema": { "$ref": "#/entities/Annotation" },
      "description": "User notes linked to documents."
    },
    "users/{userId}/reminders/{reminderId}": {
      "schema": { "$ref": "#/entities/Reminder" },
      "description": "User reminders and tasks."
    },
    "users/{userId}/whatsapp_messages/{messageId}": {
      "schema": { "$ref": "#/entities/WhatsAppMessage" },
      "description": "Logs of WhatsApp communication."
    }
  }
}
